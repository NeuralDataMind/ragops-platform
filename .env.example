# App
APP_NAME
APP_ENV
DEBUG

# API Security
API_KEY
ADMIN_API_KEY

# LLM Provider
GOOGLE_API_KEY
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash


# PostgreSQL
# Docker hostname: postgres
POSTGRES_HOST=postgres
POSTGRES_PORT
POSTGRES_DB
POSTGRES_USER
POSTGRES_PASSWORD
DATABASE_URL

# Qdrant
# Docker hostname: qdrant
QDRANT_HOST
QDRANT_PORT
QDRANT_COLLECTION_PREFIX


# Redis
# Docker hostname: redis
REDIS_HOST=redis
REDIS_PORT
REDIS_DB

# Embeddings
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSION=3072

# Chunking
DEFAULT_CHUNK_SIZE
DEFAULT_CHUNK_OVERLAP

# Retrieval
DENSE_TOP_K
SPARSE_TOP_K
RERANK_TOP_K

# Upload Limits
MAX_UPLOAD_MB
UPLOAD_DIR